{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observeos.local/contracts/sync_ack.schema.json",
  "title": "Sync Acknowledgement",
  "type": "object",
  "required": ["accepted", "duplicates", "rejected"],
  "properties": {
    "accepted": {
      "type": "array",
      "items": { "type": "string" }
    },
    "duplicates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "error"],
        "properties": {
          "event_id": { "type": "string" },
          "error": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
