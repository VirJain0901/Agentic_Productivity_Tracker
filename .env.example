# Django runtime
DJANGO_SECRET_KEY=replace-with-a-local-development-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Kolkata

# Backend services
DATABASE_URL=sqlite:///db.sqlite3
DB_ENGINE=sqlite
REDIS_URL=redis://127.0.0.1:6379/0
POSTGRES_DB=employee_tracker
POSTGRES_USER=employee_tracker
POSTGRES_PASSWORD=employee_tracker_dev_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_POOL_MAX=20

# API/client configuration
EMPLOYEE_TRACKER_API_BASE_URL=http://127.0.0.1:8000
EMPLOYEE_TRACKER_WS_BASE_URL=ws://127.0.0.1:8000
EMPLOYEE_TRACKER_POLICY_URL=https://127.0.0.1:8000/api/monitoring/policies/
EMPLOYEE_TRACKER_BLOCKLIST_URL=http://127.0.0.1:8000/api/blocklist/
EMPLOYEE_TRACKER_SYNC_URL=http://127.0.0.1:8000/api/activity-sync/
AGENT_DEVICE_ID=replace-with-device-id
AGENT_AUTH_TOKEN=replace-with-device-or-user-token
AGENT_VERIFY_TLS=true

# Monitoring policy defaults
IDLE_THRESHOLD_SECONDS=600
SCREENSHOT_CAPTURE_ENABLED=false
SCREENSHOT_INTERVAL_SECONDS=300
SCREENSHOT_RETENTION_DAYS=30

# Operations
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL_SECONDS=60
SYNC_INTERVAL_SECONDS=10

# Sync client
BACKEND_SYNC_URL=http://127.0.0.1:8000/api/activity-sync/
BACKEND_SCREENSHOT_URL=http://127.0.0.1:8000/api/screenshot/

JWT_TOKEN=replace-with-jwt-token
JWT_REFRESH_TOKEN=replace-with-refresh-token
JWT_REFRESH_URL=http://127.0.0.1:8000/api/token/refresh/
JWT_REFRESH_INTERVAL=300

SYNC_BATCH_SIZE=50
MAX_RETRY_COUNT=3

CLIENT_VERSION=1.2.0
SCHEMA_VERSION=1.0

TENANT_ID=replace-with-tenant-id
DEVICE_ID=replace-with-device-id